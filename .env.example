# Copy this file to .env and fill in your values.
# The API key is OPTIONAL — the system works fully without it
# using rule-based deterministic synthesis.

# Groq API key for LLM-powered report synthesis
# Get one (free) at: https://console.groq.com/
# Leave empty or omit to use deterministic fallback synthesis
GROQ_API_KEY=

# LLM model (default: llama-3.3-70b-versatile — best quality/speed balance on Groq)
# Alternatives: llama-3.1-8b-instant (faster, lower cost), mixtral-8x7b-32768
LLM_MODEL=llama-3.3-70b-versatile

# Max tokens for LLM responses (synthesis prompt is ~500 tokens in, ~300 out)
LLM_MAX_TOKENS=1024

# Per-tool execution timeout in seconds
TOOL_TIMEOUT=10.0

# Max retries per tool on transient failure
MAX_RETRIES=2

# Enable debug logging
DEBUG=false
